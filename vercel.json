{
  "crons": [{
    "path": "/api/admin/send-trial-emails",
    "schedule": "0 14 * * *"
  }, {
    "path": "/api/admin/refresh-projections",
    "schedule": "30 12 * * *"
  }],
  "rewrites": [
    {
      "source": "/api/supabase/(.*)",
      "destination": "/api/supabase/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
